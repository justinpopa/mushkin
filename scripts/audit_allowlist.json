  "skip_key_comments": {
    "getinfo.106/108/111/118/120": "Session state flags (connected, modified, etc.)",
    "getinfo.265-268": "OS version info (platform-specific by nature)",
    "getinfo.286-288": "Session match/fire counters",
    "getinfo.295-296": "Session redraw/scroll state",
    "getinfo.297": "Timer frequency (platform-specific)",
    "getinfo.298": "SQLite version (linked version differs)",
    "getinfo.299-300": "Code pages (Windows 1252/437 vs UTF-8 65001)",
    "getinfo.301-306": "Timestamps (session-specific)",
    "options.*": "World file config differences (different .mcl files, not code bugs)",
    "plugins.*": "Plugin data differs due to different sessions/paths",
    "api_availability.*": "Mushkin has intentional extra aliases (NoteColour, BoldColour, etc.)",
    "miniwindows.*": "Miniwindow state differs per session/display"
  },
  "normalize_paths": [
    "getinfo\\..*",
    "options\\.alpha\\..*",
    "plugins\\..*\\.variables\\..*"
  ],
  "tolerance": {
    "miniwindows\\..*\\.1": 5,
    "miniwindows\\..*\\.2": 5,
    "miniwindows\\..*\\.10": 10,
    "miniwindows\\..*\\.11": 10,
    "miniwindows\\..*\\.12": 10,
    "miniwindows\\..*\\.13": 10
  }
